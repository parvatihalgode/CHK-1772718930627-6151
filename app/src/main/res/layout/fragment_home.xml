<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Header Section with Gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back, parvathi! 👋"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Continue your learning journey"
                    android:textColor="#E0E0E0"
                    android:textSize="16sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/scoreChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Score: 0"
                    android:textColor="@color/white"
                    app:chipBackgroundColor="#6200EE"
                    app:chipIcon="@drawable/ic_battle"
                    app:chipIconTint="@color/white" />
            </LinearLayout>

            <!-- Total Usage Card (Interactive Animate) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUsage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                android:clickable="true"
                android:focusable="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivUsageIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_home"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#4285F4" />

                    <TextView
                        android:id="@+id/tvUsageTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Total Usage"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/ivUsageIcon"
                        app:layout_constraintStart_toEndOf="@id/ivUsageIcon"
                        app:layout_constraintTop_toTopOf="@id/ivUsageIcon" />

                    <TextView
                        android:id="@+id/tvUsageSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Lifetime learning time"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ivUsageIcon" />

                    <TextView
                        android:id="@+id/tvTimeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0 hrs"
                        android:textColor="#4285F4"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvUsageSub" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Across all subjects"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTimeValue" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/usageProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="0"
                        app:indicatorColor="#4CAF50"
                        app:indicatorSize="80dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:trackColor="#F5F5F5"
                        app:trackThickness="8dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="⚡ Quick Actions"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Quick Actions Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:columnCount="2">

                <!-- AI Guru -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAiGuru"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#FFF9E1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_profile" app:tint="#FFA000" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="AI Guru" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ask questions" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Practice -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPractice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_practice" app:tint="#2196F3" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Practice" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Solve problems" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Battle -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBattle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F3E5F5"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_battle" app:tint="#9C27B0" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Battle" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Compete now" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Books -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBooks"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#E8F5E9"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_practice" app:tint="#4CAF50" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Books" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Read &amp; learn" android:textSize="12sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Programming Languages Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="&lt;&gt; Programming Languages"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Programming Languages Horizontal Scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- C Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLangC"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#F8F0FF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E0E0E0"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_home" app:tint="#3F51B5"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:textStyle="bold" android:layout_marginTop="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Procedural" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Python Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLangPython"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#F8F0FF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E0E0E0"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_home" app:tint="#FFC107"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Python" android:textStyle="bold" android:layout_marginTop="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scripting" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- C++ Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLangCpp"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#F8F0FF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E0E0E0"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_home" app:tint="#673AB7"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C++" android:textStyle="bold" android:layout_marginTop="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System prog" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Java Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLangJava"
                        android:layout_width="140dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        app:cardBackgroundColor="#F8F0FF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E0E0E0"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_practice" app:tint="#4CAF50"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Java" android:textStyle="bold" android:layout_marginTop="8dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OOP" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Technical Topics Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="🧠 Technical Topics"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Technical Topics Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:columnCount="2">

                <!-- Algorithms -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTopicAlgorithms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F8F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_battle" app:tint="#FF5722"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Algorithms" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Design &amp; analysis" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Data Structures -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTopicDataStructures"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F8F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_practice" app:tint="#2196F3"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Structures" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Essentials" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Databases -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTopicDatabases"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F8F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_leaderboard" app:tint="#4CAF50"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Databases" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SQL &amp; NoSQL" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Web Dev -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTopicWebDev"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#F8F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_profile" app:tint="#9C27B0"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Web Dev" android:textStyle="bold" android:layout_marginTop="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Frontend &amp; Backend" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- More Resources Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="📚 More Resources"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- More Resources Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#F8F0FF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/btnReferenceBooks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:text="Reference Books"
                        android:drawableStart="@drawable/ic_practice"
                        android:drawablePadding="16dp"
                        android:gravity="center_vertical"
                        android:textSize="16sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginStart="52dp" android:layout_marginEnd="20dp"/>
                    <TextView
                        android:id="@+id/btnStudyNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:text="Study Notes &amp; References"
                        android:drawableStart="@drawable/ic_leaderboard"
                        android:drawablePadding="16dp"
                        android:gravity="center_vertical"
                        android:textSize="16sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>