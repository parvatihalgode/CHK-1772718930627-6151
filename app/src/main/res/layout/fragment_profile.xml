<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/header_gradient"
                android:padding="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInitials"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/white"
                    app:strokeWidth="2dp">
                    <TextView
                        android:id="@+id/tvUserInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="PA"
                        android:textColor="@color/purple_700"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/cardInitials"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="parvati"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipRole"
                        style="@style/Widget.MaterialComponents.Chip.Action"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginTop="4dp"
                        android:text="Student"
                        android:textColor="@color/white"
                        app:chipBackgroundColor="#4D000000"
                        app:chipIcon="@drawable/ic_battle"
                        app:chipIconSize="16dp"
                        app:chipIconTint="@color/white" />
                </LinearLayout>
            </RelativeLayout>

            <!-- 24-Hour Activity Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_home"
                        android:drawablePadding="8dp"
                        android:text="24-Hour Activity"
                        android:textStyle="bold"
                        app:drawableTint="#2196F3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your learning activity in the last 24 hours"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="150dp"
                            android:layout_height="150dp">

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/profileDailyProgress"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:progress="5"
                                app:indicatorColor="#FF5252"
                                app:indicatorSize="140dp"
                                app:trackColor="#F5F5F5"
                                app:trackThickness="10dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDailyPercent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5%"
                                    android:textSize="24sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Daily Goal"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </RelativeLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLearningTimeToday"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="6 minutes"
                        android:textColor="#2196F3"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Total learning time today"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvLearningGoal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Goal: 120 minutes/day"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="20dp"
                        android:background="#EEEEEE" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_algorithms"
                        android:drawablePadding="8dp"
                        android:text="Activity Breakdown"
                        android:textStyle="bold"
                        app:drawableTint="@color/black" />

                    <!-- Breakdown items -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧮 General" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvGeneralTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0m (0%)" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressGeneral"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:progress="0"
                            app:indicatorColor="#2196F3"
                            app:trackColor="#E3F2FD"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚔️ Battle" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvBattleTimeBreakdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0m (0%)" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBattle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:progress="0"
                            app:indicatorColor="#9C27B0"
                            app:trackColor="#F3E5F5"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"/>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📝 Practice" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvPracticeTimeBreakdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0m (0%)" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                        </RelativeLayout>
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressPractice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:progress="0"
                            app:indicatorColor="#4CAF50"
                            app:trackColor="#E8F5E9"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_battle" app:tint="#2196F3"/>
                        <TextView android:id="@+id/tvTotalScoreProfile" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Score" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_practice" app:tint="#9C27B0"/>
                        <TextView android:id="@+id/tvQuizzesTaken" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quizzes Taken" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_battle" app:tint="#FFA000"/>
                        <TextView android:id="@+id/tvAvgScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg Score" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_leaderboard" app:tint="#4CAF50"/>
                        <TextView android:id="@+id/tvGlobalRank" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Global Rank" android:textSize="10sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <!-- Recent Quiz Attempts -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recent Quiz Attempts" android:textStyle="bold" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Your latest quiz performances" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:id="@+id/layoutRecentAttempts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvNoAttempts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:gravity="center"
                            android:text="No quiz attempts yet. Start practicing!"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Account Actions -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Account Actions" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminPanel"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Admin Panel"
                        android:gravity="center_vertical|start"
                        android:paddingStart="16dp"
                        app:icon="@drawable/ic_profile"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProfileLogout"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Logout"
                        android:gravity="center_vertical|start"
                        android:paddingStart="16dp"
                        app:icon="@drawable/ic_home"
                        app:iconGravity="textStart"
                        app:cornerRadius="12dp"
                        android:backgroundTint="#FF5252"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
